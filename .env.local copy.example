# ==========================================
# SmartBill - 环境变量配置
# ==========================================

# Supabase 配置
# 获取地址: https://app.supabase.com/ > 你的项目 > Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
EXPO_PUBLIC_API_BASE_URL=https://smartbillpro.com

# Google 原生登录配置
# webClientId 必填, 用于 Android / iOS 获取 idToken 后换取 Supabase session
# iosClientId 建议填写 iOS OAuth client ID；如果已在 GoogleService-Info.plist 中配置可留空
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com

# 可选: Service Role Key (仅在需要服务端管理员操作时使用)
# 警告: 此 key 拥有管理员权限,切勿暴露到客户端!
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ==========================================
# 配置说明:
# 1. EXPO_PUBLIC_SUPABASE_URL: 你的 Supabase 项目 URL
# 2. EXPO_PUBLIC_SUPABASE_ANON_KEY: 公开的匿名密钥 (可安全暴露在前端)
# 3. EXPO_PUBLIC_API_BASE_URL: 业务 API 地址, 用于登录后补拉 profile
# 4. EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID: Google Cloud Console 中的 Web client ID
# 5. EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID: Google Cloud Console 中的 iOS client ID
# 6. 生产环境还需在 Supabase Dashboard > Authentication > Providers > Google 完成配置
# ==========================================
